# API Gateway Environment Variables

# The environment mode (development, production, or test)
NODE_ENV=development

# The port the API Gateway will listen on
PORT=3000

# The secret key used to sign and verify JSON Web Tokens (JWTs). Must be at least 16 characters.
JWT_SECRET=your_super_secret_key_change_in_production

# Logging verbosity level (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info

# Redis connection URL
REDIS_URL=redis://localhost:6379
